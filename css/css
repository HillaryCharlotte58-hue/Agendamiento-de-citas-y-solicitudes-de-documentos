

.dashboard, .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
}

.dashboard button {
    padding: 2rem;
    font-size: 1.2rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #064075, #0a3a71);
}
section {
  display: none;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
}
section.active {
  display: block;
  opacity: 1;
}